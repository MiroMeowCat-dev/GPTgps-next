    "faq_header":  {
                       "message":  "Frequently Asked Questions"
                   },
    "faq_permissions_header":  {
                                   "message":  "Why does this extension require reddit permissions?"
                               },
    "faq_permissions_answer":  {
                                   "message":  "The only permission we require is for our own subreddit, r/ChatGPTPromptGenius, and this is only to help format when you submit prompts to our subreddit. We also insert a button to allow you to quickly import other people’s prompts. We do not run any scripts on any other subreddit, and we do not collect any data from reddit."
                               },
    "faq_data_header":  {
                            "message":  "What do you do with my data?"
                        },
    "faq_data_answer":  {
                            "message":  "We understand that your data is important to you, and we want to assure you that it is completely under your control. All of your data is stored locally on your device, and we do not claim any ownership over it. Additionally, we do not have access to your data (we do not have servers), as it is stored solely on your device\u0027s local storage. If you choose to share a chat, it will be uploaded to a ShareGPT server, but you will still retain the rights to your data. You can export your data at any time in its raw JSON format, and we are also working on adding more export formats for your convenience."
                        },
    "faq_delete_header":  {
                              "message":  "Can I delete something I\u0027ve shared via link?"
                          },
    "faq_sharegpt_data":  {
                              "message":  "Unfortunately, we are using the public servers from ShareGPT to host your shared services. We have no way of accessing that data. We suggest you should not share any sensitive information."
                          },
    "faq_data_shared_header":  {
                                   "message":  "Is there any other data that is shared?"
                               },
    "faq_data_shared_answer":  {
                                   "message":  "Unless you explicitly share that data using the \"share link\" button, no data leaves your device. It is all stored in local storage, even exports to pdf/png/md."
                               },
    "faq_bug_header":  {
                           "message":  "I found a bug!"
